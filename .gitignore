# ---------------------------------------------------------------------------
# Data & Environment (保留你原有的配置)
# ---------------------------------------------------------------------------
notebooks/data
notebooks/cifar_net.pth
.env
.DS_Store

# ---------------------------------------------------------------------------
# Python Runtime & Notebook Caches (全面绞杀 Python 缓存)
# ---------------------------------------------------------------------------
# 💡 无论 __pycache__ 躲在哪个子文件夹深处，全局物理屏蔽
**/__pycache__/
*.py[cod]
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Testing Caches (把 pytest 缓存狠狠关在门外)
# ---------------------------------------------------------------------------
# 💡 屏蔽 pytest 的自动化运行跟踪缓存
.pytest_cache/